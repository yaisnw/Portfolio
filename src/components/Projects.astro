---
import { projects } from "../data/projects";
---

<section id="projects">
  <div class="container">
    <p class="section-label">02 / projects</p>
    <h2 class="section-title">Things I've built</h2>
    <div class="grid">
      {projects.map((p) => (
        <article class={`card ${p.featured ? "featured" : ""}`}>
          <div class="folder" aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" />
            </svg>
          </div>
          <div class="links">
            {p.github && (
              <a href={p.github} target="_blank" rel="noopener" aria-label="GitHub repository">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.2 11.4.6.1.82-.26.82-.58v-2c-3.34.72-4.04-1.6-4.04-1.6-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.2.08 1.84 1.23 1.84 1.23 1.07 1.84 2.81 1.31 3.5 1 .1-.78.42-1.31.76-1.61-2.66-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.12-3.18 0 0 1-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.3-1.55 3.3-1.23 3.3-1.23.66 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.62-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.22.69.82.57A12 12 0 0 0 24 12c0-6.63-5.37-12-12-12z" /></svg>
              </a>
            )}
            {p.demo && (
              <a href={p.demo} target="_blank" rel="noopener" aria-label="Live demo">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" /><polyline points="15 3 21 3 21 9" /><line x1="10" y1="14" x2="21" y2="3" /></svg>
              </a>
            )}
          </div>
          <h3 class="card-title">
            {(p.demo || p.github) ? (
              <a href={p.demo || p.github} target="_blank" rel="noopener">{p.title}</a>
            ) : (
              <span>{p.title}</span>
            )}
          </h3>
          <p class="card-desc">{p.description}</p>
          <ul class="card-tags">
            {p.tags.map((t) => <li>{t}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }
  .card {
    position: relative;
    padding: 2rem 1.75rem;
    background: var(--bg-alt);
    border: 1px solid var(--border);
    border-radius: 6px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .card:hover {
    transform: translateY(-4px);
    border-color: var(--border-hi);
    box-shadow: 0 12px 32px -12px rgba(0, 0, 0, 0.5);
  }
  .card.featured {
    border-color: rgba(126, 231, 135, 0.3);
    background: linear-gradient(180deg, rgba(126, 231, 135, 0.04), var(--bg-alt));
  }
  .card.featured::before {
    content: "featured";
    position: absolute;
    top: 0.9rem;
    right: 0.9rem;
    font-family: var(--mono);
    font-size: 0.65rem;
    color: var(--accent);
    background: rgba(126, 231, 135, 0.1);
    border: 1px solid rgba(126, 231, 135, 0.3);
    padding: 0.2rem 0.5rem;
    border-radius: 3px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 500;
  }
  .folder { color: var(--accent); }
  .links { display: flex; gap: 0.25rem; }
  .links a {
    color: var(--fg-muted);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 4px;
    transition: color 0.15s ease, background 0.15s ease, transform 0.15s ease;
  }
  .links a:hover {
    color: var(--accent);
    background: rgba(126, 231, 135, 0.08);
    transform: translateY(-2px);
  }
  .card-title {
    font-size: 1.2rem;
    font-weight: 600;
  }
  .card-title a { color: var(--fg); }
  .card-title a:hover { color: var(--accent); }
  .card-desc {
    font-size: 0.92rem;
    color: var(--fg-muted);
    flex: 1;
  }
  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.9rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }
  .card-tags li {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--fg-muted);
  }
</style>
